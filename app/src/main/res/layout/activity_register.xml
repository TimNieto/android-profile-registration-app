<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_app" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/profile_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="88dp"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="44dp">

            <TextView
                style="@style/ProfileTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:text="Please Enter Your Details"
                android:textSize="24sp" />

            <EditText
                android:id="@+id/etGiven"
                style="@style/ProfileInput"
                android:autofillHints="givenName"
                android:hint="Given name (e.g., Juan)"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/etSurname"
                style="@style/ProfileInput"
                android:autofillHints="familyName"
                android:hint="Surname (e.g., Dela Cruz)"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/etBirthday"
                style="@style/ProfileInput"
                android:autofillHints="birthday"
                android:hint="Birthday (yyyy-mm-dd)"
                android:inputType="date" />

            <EditText
                android:id="@+id/etGender"
                style="@style/ProfileInput"
                android:autofillHints="gender"
                android:hint="Gender (e.g., Male, Female, Other)"
                android:inputType="textCapWords" />

            <EditText
                android:id="@+id/etMobile"
                style="@style/ProfileInput"
                android:autofillHints="phone"
                android:hint="Mobile number (e.g., 09171234567)"
                android:inputType="phone"
                android:layout_marginBottom="30dp" />

            <Button
                android:id="@+id/btnRegister"
                style="@style/ProfilePrimaryButton"
                android:layout_marginBottom="30dp"
                android:text="Register" />

        </LinearLayout>
    </ScrollView>

    <TextView
        style="@style/ProfileFooterText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="34dp"
        android:gravity="center"
        android:text="Created by Tim Nieto" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/back_button_background"
        android:contentDescription="Back"
        android:padding="11dp"
        android:scaleType="center"
        android:src="@drawable/ic_back_arrow" />

</FrameLayout>