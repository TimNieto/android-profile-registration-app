<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_app" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/profile_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="88dp"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="72dp">

        <TextView
            style="@style/ProfileTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Profile Summary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvFullName"
            style="@style/ProfileResultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvBirthday"
            style="@style/ProfileResultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvAge"
            style="@style/ProfileResultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvZodiac"
            style="@style/ProfileResultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvGender"
            style="@style/ProfileResultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvMobile"
            style="@style/ProfileResultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvTelecom"
            style="@style/ProfileResultText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp" />

    </LinearLayout>

    <TextView
        style="@style/ProfileFooterText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="34dp"
        android:gravity="center"
        android:text="Created by Tim Nieto" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/back_button_background"
        android:contentDescription="Back"
        android:padding="11dp"
        android:scaleType="center"
        android:src="@drawable/ic_back_arrow" />

</FrameLayout>